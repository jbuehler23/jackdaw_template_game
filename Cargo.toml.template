[package]
name = "{{project-name}}"
authors = ["{{authors}}"]
version = "0.1.0"
edition = "2024"
publish = false

# Mark as its own workspace root so it doesn't get pulled into
# whatever parent workspace the user happens to scaffold under.
[workspace]

[lib]
crate-type = ["cdylib"]

# Intentionally empty. `bevy`, `jackdaw_api`, and (later)
# `jackdaw_game` are injected via `--extern` flags by the jackdaw
# editor's build pipeline.
[dependencies]
